# ---- Phase 26 asset generation ---------------------------------------------
# Raw AI-generated assets before human/Tusk QC — never commit
src/assets/source/generated/

# Top-level /assets/ holds symlinks/copies referenced by app.json;
# committed, but the symlinks themselves are platform-specific.
# Comment-out if you prefer explicit copies over symlinks.
# assets/*.symlink

# ---- Docs runtime captures (renderer output + on-device captures) ---------
docs/screenshots/
docs/device-qa/

# ---- Root-level one-off / stale artifacts (not durable baseline) ---------
font-test.png
qr/
phase7-npm-audit.json
.hermes/verification-cache.json
artifacts/releases/

# ---- Generated code graph -------------------------------------------------
# Keep the current graph/report/manifest as the project's shared knowledge
# baseline. Ignore volatile AST caches and dated local snapshots only.
graphify-out/*
!graphify-out/.graphify_root
!graphify-out/.graphify_labels.json
!graphify-out/GRAPH_REPORT.md
!graphify-out/graph.json
!graphify-out/graph.html
!graphify-out/manifest.json
dist/
tmp-*.svg

# ---- Generated local QA / one-off patch artifacts -------------------------
.maestro/*-results.xml
scripts/_patch_*.py
src/assets/source/**/_backup_*
