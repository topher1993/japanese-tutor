{
  "name": "koi-sensei-cloudflare-worker",
  "version": "2.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "types": "wrangler types src/worker-configuration.d.ts --config wrangler.jsonc --include-runtime false",
    "types:check": "wrangler types src/worker-configuration.d.ts --config wrangler.jsonc --include-runtime false --check",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "build:check": "wrangler deploy --dry-run --config wrangler.jsonc"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "5.20260719.1",
    "typescript": "5.9.3",
    "wrangler": "4.112.0"
  }
}
