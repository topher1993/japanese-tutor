# Koi Sensei Functions emulator configuration. Copy to `functions/.env`.
# This safe default never contacts MiniMax.
KOI_DEPLOY_ENV=development
KOI_PROVIDER_MODE=mock
KOI_MOCK_REMAINING_PERCENT=100
KOI_ACTIVE_ACCOUNT_LIMIT=50
KOI_PROVIDER_MAX_CONCURRENCY=2

# These must remain false until each external gate is independently resolved.
KOI_MINIMAX_MULTI_USER_APPROVED=false
KOI_MINIMAX_NO_CREDITS_ATTACHED_ATTESTED=false
KOI_FIREBASE_BILLING_RISK_APPROVED=false

# Never put MINIMAX_TOKEN_PLAN_KEY here. Live Functions accept it only through
# Secret Manager. Pay-as-you-go credential variable names are rejected.
