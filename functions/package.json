{
  "name": "japanese-tutor-koi-functions",
  "version": "2.0.0",
  "private": true,
  "type": "module",
  "main": "lib/functions/src/index.js",
  "engines": {
    "node": "22"
  },
  "scripts": {
    "build": "node scripts/clean-build.mjs && tsc -p tsconfig.json",
    "emulators": "firebase emulators:start --project demo-koi-sensei --only auth,functions,firestore,storage",
    "test": "vitest run --config vitest.config.ts",
    "test:rules:emulator": "firebase emulators:exec --project demo-koi-sensei --only firestore,storage \"vitest run --config vitest.emulator.config.ts\"",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.tests.json"
  },
  "dependencies": {
    "firebase-admin": "13.10.0",
    "firebase-functions": "7.2.5",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@firebase/rules-unit-testing": "5.0.1",
    "@types/node": "26.0.0",
    "firebase": "12.16.0",
    "firebase-tools": "15.24.0",
    "typescript": "5.9.3",
    "vitest": "4.1.9"
  }
}
