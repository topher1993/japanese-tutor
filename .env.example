# Japanese Tutor — Environment Variables
#
# Copy this file to `.env` and fill in real values.
# `.env` is gitignored (see .gitignore).
#
# Phase 44 — Analytics (telemetry) keys.
# `EXPO_PUBLIC_*` prefix is required by Expo to inline the value into the
# client bundle at build time. See:
# https://docs.expo.dev/guides/environment-variables/

# PostHog project API key (https://posthog.com/docs/api).
# Format: `phc_<project>_<random>`.
# When unset, `isAnalyticsEnabled()` returns false and `track()` is a no-op
# (events are still queued in dev mode for the debug UI, but not transmitted).
EXPO_PUBLIC_ANALYTICS_KEY=

# Optional: backend override. Defaults to PostHog when an analytics key is set.
# Future: 'amplitude' | 'firebase' | 'console' (dev only).
# EXPO_PUBLIC_ANALYTICS_BACKEND=posthog