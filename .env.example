# Japanese Tutor — Environment Variables
#
# Copy this file to `.env` and fill in real values.
# `.env` is gitignored (see .gitignore).
#
# Phase 44 — Analytics (telemetry) keys.
# `EXPO_PUBLIC_*` prefix is required by Expo to inline the value into the
# client bundle at build time. See:
# https://docs.expo.dev/guides/environment-variables/

# PostHog project API key (https://posthog.com/docs/api).
# Format: `phc_<project>_<random>`.
# When unset, `isAnalyticsEnabled()` returns false and no event is transmitted;
# development builds may retain a bounded in-memory queue for debugging.
EXPO_PUBLIC_ANALYTICS_KEY=

# Optional PostHog ingest host override (for EU cloud or self-hosting).
# Defaults to https://us.i.posthog.com.
EXPO_PUBLIC_POSTHOG_HOST=

# ---------------------------------------------------------------------------
# Koi Sensei Firebase client identifiers (public configuration, never secrets)
# Use one matching dev/staging/prod project per build profile. Do not commit the
# generated google-services.json or GoogleService-Info.plist files.
# ---------------------------------------------------------------------------
# Safe default: deterministic local answers and no provider/network call.
EXPO_PUBLIC_KOI_STAGE=mock
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=
EXPO_PUBLIC_FIREBASE_APP_CHECK_SITE_KEY=
EXPO_PUBLIC_FIREBASE_FUNCTIONS_REGION=us-central1
EXPO_PUBLIC_KOI_WORKER_URL=https://koi-sensei-personal.swtopherpid09.workers.dev
EXPO_PUBLIC_KOI_EMAIL_LINK_URL=

# Development/staging only. Production config rejects any emulator origin.
EXPO_PUBLIC_FIREBASE_FUNCTIONS_EMULATOR_ORIGIN=
EXPO_PUBLIC_FIREBASE_AUTH_EMULATOR_ORIGIN=

# Never add EXPO_PUBLIC_MINIMAX_* or EXPO_PUBLIC_TOKEN_PLAN_* variables. Expo
# public variables are embedded in the app bundle; the Koi runtime rejects
# secret-like provider variables.
