{
  "name": "japanese-tutor-mobile-app",
  "version": "2.0.0",
  "private": true,
  "packageManager": "npm@11.12.1",
  "engines": {
    "node": ">=20.19.4",
    "npm": ">=10"
  },
  "expo": {
    "doctor": {
      "appConfigFieldsNotSyncedCheck": {
        "enabled": false
      }
    }
  },
  "main": "expo/AppEntry.js",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "test": "vitest run",
    "test:koi": "vitest run koiSensei",
    "typecheck": "tsc --noEmit",
    "validate:v2": "npm run typecheck && npm test && npm --prefix functions run typecheck && npm --prefix functions test && npm --prefix functions run build && npm --prefix cloudflare/koi-worker run typecheck && npm --prefix cloudflare/koi-worker run build:check",
    "koi:avatar:generate": "node src/features/koi-sensei/media/placeholder/generatePlaceholderGlb.mjs",
    "validate:v11": "npm run typecheck && npm test -- --run",
    "setup:romanizer": "python -m pip install -r scripts/requirements-romanizer.txt",
    "romanize:examples": "python scripts/romanize-japanese.py --level N4 --check",
    "romanize:examples:write": "python scripts/romanize-japanese.py --level N4 --write --check",
    "import:jmdict": "node scripts/import-jmdict-vocab.mjs",
    "generate:verbs": "node scripts/generate-verb-candidates.mjs",
    "import:kanjidic2": "node scripts/import-kanjidic2.mjs",
    "audit:deps": "npm audit --omit=dev --audit-level=moderate",
    "audit:report": "node scripts/audit-report.mjs"
  },
  "overrides": {
    "brace-expansion@1.1.15": "1.1.16",
    "brace-expansion@5.0.6": "5.0.7",
    "shell-quote@1.8.4": "1.10.0",
    "@istanbuljs/load-nyc-config": {
      "js-yaml": "3.15.0"
    }
  },
  "dependencies": {
    "@expo/metro-runtime": "6.1.2",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-firebase/app": "25.1.0",
    "@react-native-firebase/app-check": "25.1.0",
    "@react-native-firebase/auth": "25.1.0",
    "@react-native-firebase/functions": "25.1.0",
    "@react-three/fiber": "9.6.1",
    "expo": "~54.0.36",
    "expo-asset": "12.0.13",
    "expo-audio": "1.1.1",
    "expo-build-properties": "1.0.10",
    "expo-file-system": "19.0.23",
    "expo-gl": "16.0.10",
    "expo-haptics": "15.0.8",
    "expo-screen-orientation": "~9.0.9",
    "expo-speech": "~14.0.8",
    "expo-speech-recognition": "3.1.3",
    "expo-splash-screen": "31.0.13",
    "expo-sqlite": "16.0.10",
    "firebase": "12.16.0",
    "posthog-react-native": "4.54.4",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-reanimated": "4.1.7",
    "react-native-safe-area-context": "5.6.2",
    "react-native-svg": "15.12.1",
    "react-native-web": "0.21.2",
    "react-native-worklets": "^0.5.1",
    "three": "0.185.1"
  },
  "devDependencies": {
    "@expo/ngrok": "^4.1.3",
    "@types/node": "^26.0.0",
    "@types/react": "19.1.17",
    "@types/three": "0.185.1",
    "babel-preset-expo": "^54.0.10",
    "sharp": "^0.35.3",
    "typescript": "5.9.3",
    "vitest": "4.1.9"
  }
}
