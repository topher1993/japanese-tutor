{
  "name": "japanese-tutor-mobile-app",
  "version": "0.1.0",
  "private": true,
  "main": "expo/AppEntry.js",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "import:jmdict": "node scripts/import-jmdict-vocab.mjs",
    "import:kanjidic2": "node scripts/import-kanjidic2.mjs",
    "audit:deps": "npm audit --omit=dev --audit-level=moderate",
    "audit:report": "node scripts/audit-report.mjs"
  },
  "dependencies": {
    "@expo/metro-runtime": "6.1.2",
    "expo": "54.0.35",
    "expo-build-properties": "1.0.10",
    "expo-haptics": "15.0.8",
    "expo-splash-screen": "31.0.13",
    "expo-sqlite": "16.0.10",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-reanimated": "4.1.7",
    "react-native-safe-area-context": "5.6.2",
    "react-native-svg": "15.12.1",
    "react-native-web": "0.21.2",
    "react-native-worklets": "^0.5.1"
  },
  "devDependencies": {
    "@expo/ngrok": "^4.1.3",
    "@types/node": "^26.0.0",
    "@types/react": "19.1.17",
    "babel-preset-expo": "^54.0.10",
    "typescript": "5.9.3",
    "vitest": "4.1.9"
  }
}
