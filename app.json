{
  "expo": {
    "name": "Japanese Tutor",
    "slug": "japanese-tutor-mobile-app",
    "version": "1.1.0",
    "orientation": "default",
    "userInterfaceStyle": "light",
    "assetBundlePatterns": [
      "**/*"
    ],
    "icon": "./assets/icon-v1.png",
    "ios": {
      "icon": "./assets/icon-v1.png",
      "buildNumber": "1",
      "supportsTablet": true,
      "bundleIdentifier": "com.belion.japanesetutor",
      "infoPlist": {
        "UIBackgroundModes": ["audio"]
      }
    },
    "android": {
      "icon": "./assets/icon-v1.png",
      "package": "com.belion.japanesetutor",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-foreground-v1.png",
        "backgroundImage": "./src/assets/source/adaptive/android-adaptive-background-1080.png",
        "monochromeImage": "./assets/adaptive-monochrome-v1.png",
        "backgroundColor": "#2A6F97"
      }
    },
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#2A6F97",
      "dark": {
        "image": "./assets/splash.png",
        "resizeMode": "contain",
        "backgroundColor": "#0F172A"
      }
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-screen-orientation",
      "expo-sqlite",
      [
        "expo-build-properties",
        {
          "ios": { "deploymentTarget": "16.4" },
          "android": { "minSdkVersion": 24 }
        }
      ]
    ]
  }
}
